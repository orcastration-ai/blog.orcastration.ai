---
import Base from "../layouts/Base.astro";
---

<Base
  title="Blog — Orca"
  description="Insights, updates, and stories from the Orca team."
>
  <main class="coming-soon">
    <div class="coming-soon-content">
      <img src="/favicon.svg" alt="Orca" width="48" height="48" class="logo" />
      <span class="orca-section-label">Coming Soon</span>
      <h1 class="orca-section-title"><span class="orca-gradient-text">Blog</span></h1>
      <p class="orca-section-lead">Insights, updates, and stories from the Orca team.</p>
      <a href="https://orcastration.ai" class="orca-link-underline">orcastration.ai</a>
    </div>
  </main>
</Base>

<style>
  .coming-soon {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px 24px;
    position: relative;
    z-index: 1;
  }

  .coming-soon-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    transition:
      opacity 0.8s var(--orca-ease-out),
      transform 0.8s var(--orca-ease-out);

    @starting-style {
      opacity: 0;
      transform: translateY(30px);
    }
  }

  .logo {
    margin-bottom: 16px;
  }

  @media (prefers-reduced-motion: reduce) {
    .coming-soon-content {
      transition: none;
    }
  }
</style>
